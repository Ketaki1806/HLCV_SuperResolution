# Downsample COCO val2017 and compute PSNR/SSIM (CPU job).
#
# One-time:
#   mkdir -p ~/condor_logs
#
# Submit:
#   cd ~/super_resolution/scripts/condor
#   condor_submit downsample_val2017_metrics.sub
#
# Logs:
#   tail -f ~/condor_logs/downsample_val2017.*.out

universe                = docker
docker_image            = nvidia/cuda:11.4.3-runtime-ubuntu20.04
executable              = execute.sh

# Use the same pattern as gpu_instructions/execute.sh: call python by absolute path.
environment             = CONDA_PYTHON_BINARY_PATH=/home/hlcv_team019/miniconda3/envs/hlcv/bin/python

# Uses COCO_ROOT from execute.sh (defaults to /scratch/teaching/hlcv/hlcv_team019/coco)
arguments               = scripts/preprocessing/downsample_coco_val2017.py --coco-root /scratch/teaching/hlcv/hlcv_team019/coco --output-dir /scratch/teaching/hlcv/hlcv_team019/coco_preprocessed/val2017_lr_x2 --scale 2 --blur --blur-kernel 5 --blur-sigma 2 --metrics

output                  = /home/hlcv_team019/condor_logs/downsample_val2017.$(ClusterId).$(ProcId).out
error                   = /home/hlcv_team019/condor_logs/downsample_val2017.$(ClusterId).$(ProcId).err
log                     = /home/hlcv_team019/condor_logs/downsample_val2017.$(ClusterId).log

should_transfer_files   = YES
when_to_transfer_output = ON_EXIT

request_GPUs            = 0
request_CPUs            = 2
request_memory          = 8G
request_disk            = 6G
requirements            = UidDomain == "cs.uni-saarland.de"
+WantGPUHomeMounted     = true
queue 1

